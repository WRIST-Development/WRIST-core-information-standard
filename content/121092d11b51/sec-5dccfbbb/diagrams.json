    {
      "id": "CISV2.BP.E",
      "processId": "CISV2.E",
      "title": "Information Sharing for Integrated Care",
      "personas": "Information Manager, General Practitioner, Social Worker, Person/Patient",
      "objectives": "Enable secure, consent-based sharing of information across health and social care boundaries",
      "diagram": {
        "nodes": [
          {
            "id": "start",
            "type": "start",
            "label": "Information request received"
          },
          {
            "id": "identify",
            "type": "activity",
