{
  "summary_markdown": "The Core Information Standard defines five key business processes that support integrated care delivery. These range from initial person registration and assessment through to ongoing care coordination and information sharing. Each process involves multiple personas working collaboratively to ensure comprehensive, person-centred information management.",
  "activities": [
    {
      "id": "CISV2.BP.A",
      "processId": "CISV2.A",
      "title": "Person Registration and Demographics Management",
      "personas": "Information Manager, General Practitioner",
      "objectives": "Establish accurate person identity and demographic information to enable safe care delivery and information sharing across services",
      "diagram": {
        "nodes": [
          {
            "id": "start",
            "type": "start",
            "label": "Person presents for registration"
          },
          {
            "id": "collect",
            "type": "activity",
            "label": "Collect demographic details",
            "dataSeen": [
              {
                "element": "Existing records",
                "source": "PDS/Local systems"
              }
            ],
            "dataCollected": [
              {
                "element": "Person name",
                "notes": "All name components"
              },
              {
                "element": "Date of birth"
              },
              {
                "element": "NHS number",
                "type": "Identifier"
              },
              {
                "element": "Contact details"
              }
            ]
          },
          {
            "id": "verify",
            "type": "activity",
            "label": "Verify NHS number",
            "dataSeen": [
              {
                "element": "NHS number",
                "source": "Person/PDS"
              }
            ],
            "dataCollected": [
              {
                "element": "NHS number status",
                "notes": "Verification indicator"
              }
            ]
          },
          {
            "id": "capture",
            "type": "activity",
            "label": "Capture additional demographics",
            "dataCollected": [
              {
                "element": "Gender",
                "type": "Demographics"
              },
              {
                "element": "Ethnicity"
              },
              {
                "element": "GP practice details"
              },
              {
                "element": "Immigration status",
                "notes": "If applicable"
              }
            ]
          },
          {
            "id": "decision",
            "type": "decision",
            "label": "Reasonable adjustments needed?",
            "dataSeen": [
              {
                "element": "Person requirements",
                "source": "Assessment"
              }
            ]
          },
          {
            "id": "record",
            "type": "activity",
            "label": "Record adjustments",
            "dataCollected": [
              {
                "element": "Reasonable adjustment flags"
              },
              {
                "element": "Communication needs"
              },
              {
                "element": "Accessibility requirements"
              }
            ]
          },
          {
            "id": "complete",
            "type": "activity",
            "label": "Complete registration",
            "dataCollected": [
              {
                "element": "Registration confirmation"
              },
              {
                "element": "Audit trail"
              }
            ]
          },
          {
            "id": "end",
            "type": "end",
            "label": "Registration complete"
          }
        ],
        "edges": [
          {
            "from": "start",
            "to": "collect"
          },
          {
            "from": "collect",
            "to": "verify"
          },
          {
            "from": "verify",
            "to": "capture"
          },
          {
            "from": "capture",
            "to": "decision"
          },
          {
            "from": "decision",
            "to": "record",
            "label": "Yes"
          },
          {
            "from": "decision",
            "to": "complete",
            "label": "No"
          },
          {
            "from": "record",
            "to": "complete"
          },
          {
            "from": "complete",
            "to": "end"
          }
        ]
      }
    },
    {
      "id": "CISV2.BP.B",
      "processId": "CISV2.B",
      "title": "Initial Assessment and Care Planning",
      "personas": "Social Worker, Community Nurse, Person/Patient, Family Carer",
      "objectives": "Conduct comprehensive assessment of person's needs, preferences and circumstances to develop personalised care plan",
      "diagram": {
        "nodes": [
          {
            "id": "start",
            "type": "start",
            "label": "Assessment referral received"
          },
          {
            "id": "review",
            "type": "activity",
            "label": "Review existing information",
            "dataSeen": [
              {
                "element": "Problem list",
                "source": "Clinical records"
              },
              {
                "element": "Previous assessments"
              },
              {
                "element": "About me information"
              }
            ]
          },
          {
            "id": "prepare",
            "type": "activity",
            "label": "Prepare for assessment",
            "dataSeen": [
              {
                "element": "Reasonable adjustments"
              },
              {
                "element": "Communication needs"
              }
            ],
            "dataCollected": [
              {
                "element": "Assessment arrangements"
              }
            ]
          },
          {
            "id": "conduct",
            "type": "activity",
            "label": "Conduct assessment with person",
            "dataCollected": [
              {
                "element": "Social circumstances"
              },
              {
                "element": "Household composition"
              },
              {
                "element": "Mobility needs"
              },
              {
                "element": "Cognitive assessment",
                "notes": "If indicated"
              }
            ]
          },
          {
            "id": "goals",
            "type": "activity",
            "label": "Discuss goals and preferences",
            "dataCollected": [
              {
                "element": "Person goals and hopes"
              },
              {
                "element": "Strengths and assets"
              },
              {
                "element": "Preferred outcomes"
              }
            ]
          },
          {
            "id": "decision",
            "type": "decision",
            "label": "Safeguarding concerns?",
            "dataSeen": [
              {
                "element": "Risk indicators",
                "source": "Assessment findings"
              }
            ]
          },
          {
            "id": "safeguard",
            "type": "subprocess",
            "label": "Initiate safeguarding process",
            "dataCollected": [
              {
                "element": "Safeguarding alert"
              },
              {
                "element": "Risk assessment"
              }
            ]
          },
          {
            "id": "plan",
            "type": "activity",
            "label": "Develop care plan",
            "dataCollected": [
              {
                "element": "Care plan actions"
              },
              {
                "element": "Support requirements"
              },
              {
                "element": "Review dates"
              }
            ]
          },
          {
            "id": "agree",
            "type": "activity",
            "label": "Agree plan with person",
            "dataCollected": [
              {
                "element": "Person agreement",
                "notes": "Or legitimate representative"
              },
              {
                "element": "Consent records"
              }
            ]
          },
          {
            "id": "end",
            "type": "end",
            "label": "Assessment complete"
          }
        ],
        "edges": [
          {
            "from": "start",
            "to": "review"
          },
          {
            "from": "review",
            "to": "prepare"
          },
          {
            "from": "prepare",
            "to": "conduct"
          },
          {
            "from": "conduct",
            "to": "goals"
          },
          {
            "from": "goals",
            "to": "decision"
          },
          {
            "from": "decision",
            "to": "safeguard",
            "label": "Yes"
          },
          {
            "from": "decision",
            "to": "plan",
            "label": "No"
          },
          {
            "from": "safeguard",
            "to": "plan"
          },
          {
            "from": "plan",
            "to": "agree"
          },
          {
            "from": "agree",
            "to": "end"
          }
        ]
      }
    },
    {
