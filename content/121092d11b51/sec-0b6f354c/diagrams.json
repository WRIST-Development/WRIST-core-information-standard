{
  "summary_markdown": "Core workflows include patient registration, clinical assessments, care planning, and information sharing processes.",
  "activities": [
    {
      "id": "CISV2.BP1",
      "title": "Patient Registration Workflow",
      "objectives": "Capture complete demographic information and establish consent for information sharing",
      "diagram": {
        "nodes": [
          {
            "id": "start",
            "type": "start",
            "label": "Registration Request"
          },
          {
            "id": "verify",
            "type": "activity",
            "label": "Verify Identity",
            "dataSeen": [
              {
                "element": "Photo ID",
                "source": "Person",
                "type": "Document"
              },
              {
                "element": "Proof of Address",
                "source": "Person",
                "type": "Document"
              }
            ],
            "dataCollected": [
              {
                "element": "Identity Verification Status",
                "type": "Boolean"
              }
            ]
          },
          {
            "id": "pds",
            "type": "activity",
            "label": "Check PDS",
            "dataSeen": [
              {
                "element": "NHS Number",
                "source": "PDS",
                "type": "Identifier"
              },
              {
                "element": "Previous GP",
                "source": "PDS",
                "type": "Reference"
              }
            ],
            "dataCollected": [
              {
                "element": "PDS Match Status",
                "type": "Code"
              }
            ]
          },
          {
            "id": "demographics",
            "type": "activity",
            "label": "Capture Demographics",
            "dataSeen": [
              {
                "element": "Personal Details",
                "source": "Person",
                "type": "Form"
              }
            ],
            "dataCollected": [
              {
                "element": "Person Name",
                "type": "String"
              },
              {
                "element": "Date of Birth",
                "type": "Date"
              },
              {
                "element": "Address",
                "type": "Complex"
              },
              {
                "element": "Contact Details",
                "type": "Complex"
              }
            ]
          },
          {
            "id": "consent",
            "type": "activity",
            "label": "Record Consent",
            "dataSeen": [
              {
                "element": "Consent Form",
                "source": "Person",
                "type": "Document"
              }
            ],
            "dataCollected": [
              {
                "element": "Information Sharing Consent",
                "type": "Boolean"
              },
              {
                "element": "Consent Date",
                "type": "DateTime"
              }
            ]
          },
          {
            "id": "end",
            "type": "end",
            "label": "Registration Complete"
          }
        ],
        "edges": [
          {
            "from": "start",
            "to": "verify"
          },
          {
            "from": "verify",
            "to": "pds"
          },
          {
            "from": "pds",
            "to": "demographics"
          },
          {
            "from": "demographics",
            "to": "consent"
          },
          {
            "from": "consent",
            "to": "end"
          }
        ]
      }
    },
    {
