{
  "summary_markdown": "The Core Information Standard v2.0 defines five primary business processes that span initial registration through ongoing care management. Each process involves multiple personas working collaboratively to capture, maintain, and utilize person-centered information effectively.",
  "activities": [
    {
      "id": "initial-registration",
      "processId": "CISV2.A",
      "title": "Initial Person Registration & Demographics Capture",
      "personas": "GP/Primary Care Physician, Care Home Manager, Social Worker",
      "objectives": "Establish person's identity, capture core demographics, and register individual requirements including reasonable adjustments",
      "diagram": {
        "nodes": [
          {
            "id": "start",
            "type": "start",
            "label": "Person presents for registration"
          },
          {
            "id": "check-nhs",
            "type": "activity",
            "label": "Check NHS number/existing records",
            "dataSeen": [
              {
                "element": "NHS number",
                "source": "PDS/existing systems"
              }
            ],
            "dataCollected": []
          },
          {
            "id": "identity-decision",
            "type": "decision",
            "label": "Existing NHS number?"
          },
          {
            "id": "verify-identity",
            "type": "activity",
            "label": "Verify identity and demographics",
            "dataSeen": [
              {
                "element": "Photo ID",
                "source": "Person"
              }
            ],
            "dataCollected": [
              {
                "element": "Person name",
                "notes": "Including preferred name"
              },
              {
                "element": "Date of birth"
              },
              {
                "element": "Gender"
              },
              {
                "element": "Ethnicity"
              }
            ]
          },
          {
            "id": "create-nhs",
            "type": "activity",
            "label": "Create NHS number registration",
            "dataSeen": [],
            "dataCollected": [
              {
                "element": "NHS number",
                "notes": "New allocation"
              }
            ]
          },
          {
            "id": "capture-contact",
            "type": "activity",
            "label": "Capture contact details",
            "dataSeen": [],
            "dataCollected": [
              {
                "element": "Address",
                "notes": "Including type"
              },
              {
                "element": "Telephone numbers"
              },
              {
                "element": "Email addresses"
              },
              {
                "element": "Preferred contact method"
              }
            ]
          },
          {
            "id": "assess-requirements",
            "type": "activity",
            "label": "Assess individual requirements",
            "dataSeen": [
              {
                "element": "Previous assessments",
                "source": "Referral/records"
              }
            ],
            "dataCollected": [
              {
                "element": "Reasonable adjustments",
                "notes": "Per Equality Act 2010"
              },
              {
                "element": "Communication needs"
              },
              {
                "element": "Impairments"
              },
              {
                "element": "Mobility needs"
              }
            ]
          },
          {
            "id": "register-gp",
            "type": "activity",
            "label": "Register with GP practice",
            "dataSeen": [],
            "dataCollected": [
              {
                "element": "GP practice details"
              },
              {
                "element": "GP name"
              }
            ]
          },
          {
            "id": "end",
            "type": "end",
            "label": "Registration complete"
          }
        ],
        "edges": [
          {
            "from": "start",
            "to": "check-nhs"
          },
          {
            "from": "check-nhs",
            "to": "identity-decision"
          },
          {
            "from": "identity-decision",
            "to": "verify-identity",
            "label": "Yes"
          },
          {
            "from": "identity-decision",
            "to": "create-nhs",
            "label": "No"
          },
          {
            "from": "create-nhs",
            "to": "verify-identity"
          },
          {
            "from": "verify-identity",
            "to": "capture-contact"
          },
          {
            "from": "capture-contact",
            "to": "assess-requirements"
          },
          {
            "from": "assess-requirements",
            "to": "register-gp"
          },
          {
            "from": "register-gp",
            "to": "end"
          }
        ]
      }
    },
    {
      "id": "clinical-assessment",
      "processId": "CISV2.B",
      "title": "Clinical Assessment & Care Planning",
      "personas": "Hospital Consultant, Community Nurse, GP/Primary Care Physician, Patient/Service User, Family Carer",
      "objectives": "Conduct comprehensive health assessment, identify care needs, and develop person-centered care plan",
      "diagram": {
        "nodes": [
          {
            "id": "start",
            "type": "start",
            "label": "Assessment initiated"
          },
          {
            "id": "review-history",
            "type": "activity",
            "label": "Review medical history",
            "dataSeen": [
              {
                "element": "Problem list",
                "source": "EPR/GP records"
              },
              {
                "element": "Medications",
                "source": "EPR"
              },
              {
                "element": "Allergies",
                "source": "EPR"
              }
            ],
            "dataCollected": []
          },
          {
            "id": "clinical-exam",
            "type": "activity",
            "label": "Conduct clinical examination",
            "dataSeen": [],
            "dataCollected": [
              {
                "element": "Examination findings"
              },
              {
                "element": "Observations",
                "notes": "Vitals, measurements"
              }
            ]
          },
          {
            "id": "risk-assess",
            "type": "activity",
            "label": "Assess risks",
            "dataSeen": [
              {
                "element": "Previous risks",
                "source": "Care records"
              }
            ],
            "dataCollected": [
              {
                "element": "Risk assessment",
                "notes": "Self-harm, falls, safeguarding"
              }
            ]
          },
          {
            "id": "capacity-decision",
            "type": "decision",
            "label": "Mental capacity assessment needed?"
          },
          {
            "id": "capacity-assess",
            "type": "activity",
            "label": "Conduct capacity assessment",
            "dataSeen": [],
            "dataCollected": [
              {
                "element": "Mental capacity assessment"
              },
              {
                "element": "Best interests decision",
                "notes": "If lacks capacity"
              }
            ]
          },
          {
            "id": "develop-plan",
            "type": "activity",
            "label": "Develop care plan with person",
            "dataSeen": [
              {
                "element": "Person preferences",
                "source": "About Me section"
              }
            ],
            "dataCollected": [
              {
                "element": "Care plan goals"
              },
              {
                "element": "Actions and activities"
              },
              {
                "element": "Agreed with person"
              }
            ]
          },
          {
            "id": "document-plan",
            "type": "activity",
            "label": "Document care decisions",
            "dataSeen": [],
            "dataCollected": [
              {
                "element": "Plan and requested actions"
              },
              {
                "element": "Contingency plans"
              },
              {
                "element": "Review date"
              }
            ]
          },
          {
            "id": "end",
            "type": "end",
            "label": "Assessment complete"
          }
        ],
        "edges": [
          {
            "from": "start",
            "to": "review-history"
          },
          {
            "from": "review-history",
            "to": "clinical-exam"
          },
          {
            "from": "clinical-exam",
            "to": "risk-assess"
          },
          {
            "from": "risk-assess",
            "to": "capacity-decision"
          },
          {
            "from": "capacity-decision",
            "to": "capacity-assess",
            "label": "Yes"
          },
          {
            "from": "capacity-decision",
            "to": "develop-plan",
            "label": "No"
          },
          {
            "from": "capacity-assess",
            "to": "develop-plan"
          },
          {
            "from": "develop-plan",
            "to": "document-plan"
          },
          {
            "from": "document-plan",
            "to": "end"
          }
        ]
      }
    },
    {
