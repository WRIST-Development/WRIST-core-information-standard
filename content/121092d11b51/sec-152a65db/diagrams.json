        "nodes": [
          {
            "id": "start",
            "type": "start",
            "label": "Person presents to A&E"
          },
          {
            "id": "triage",
            "type": "activity",
            "label": "Triage Assessment",
            "dataSeen": [
              {
                "element": "NHS Number",
                "source": "PDS lookup",
                "type": "identifier"
              },
              {
                "element": "Previous alerts",
                "source": "EPR",
                "type": "alert"
              }
            ],
            "dataCollected": [
              {
                "element": "Presenting complaint",
                "notes": "Chief concern",
                "type": "clinical"
              },
              {
                "element": "Vital signs",
                "notes": "BP, pulse, temp",
                "type": "observation"
              }
            ]
          },
          {
            "id": "check_capacity",
            "type": "decision",
            "label": "Has capacity?",
            "dataSeen": [
              {
                "element": "Mental capacity status",
                "source": "Previous records",
                "type": "legal"
              }
            ],
            "dataCollected": []
          },
          {
            "id": "collect_info",
            "type": "activity",
            "label": "Collect Critical Information",
            "dataSeen": [
              {
                "element": "GP details",
                "source": "PDS",
                "type": "contact"
              },
              {
                "element": "Previous admissions",
                "source": "EPR",
                "type": "history"
              }
            ],
            "dataCollected": [
              {
                "element": "Allergies",
                "notes": "Verify with patient",
                "type": "clinical"
              },
              {
                "element": "Current medications",
                "notes": "Medicine reconciliation",
                "type": "medication"
              },
              {
                "element": "Emergency contacts",
                "type": "contact"
              }
            ]
          },
          {
            "id": "best_interests",
            "type": "subprocess",
            "label": "Best Interests Process",
            "dataSeen": [
              {
                "element": "LPA details",
                "source": "Legal records",
                "type": "legal"
              }
            ],
            "dataCollected": [
              {
                "element": "Best interests decision",
