{
  "summary_markdown": "Three critical workflows support the implementation of the Core Information Standard: emergency admission, care assessment, and care transfer processes.",
  "activities": [
    {
      "id": "CISV2.BP1",
      "title": "Emergency Admission Process",
      "objectives": "Rapidly capture and access critical information during emergency admission",
