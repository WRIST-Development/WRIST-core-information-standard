                "type": "legal"
              },
              {
                "element": "Consultation record",
                "type": "documentation"
              }
            ]
          },
          {
            "id": "admit",
            "type": "activity",
            "label": "Complete Admission",
            "dataSeen": [
              {
                "element": "Bed availability",
                "source": "Bed management",
                "type": "resource"
              }
            ],
            "dataCollected": [
              {
                "element": "Admission details",
                "type": "administrative"
              },
              {
                "element": "Initial care plan",
                "type": "care_plan"
              }
            ]
          },
          {
            "id": "end",
            "type": "end",
            "label": "Admission complete"
          }
        ],
        "edges": [
          {
            "from": "start",
            "to": "triage"
          },
          {
            "from": "triage",
            "to": "check_capacity"
          },
          {
            "from": "check_capacity",
            "to": "collect_info",
            "label": "Yes"
          },
          {
            "from": "check_capacity",
            "to": "best_interests",
            "label": "No"
          },
          {
            "from": "collect_info",
            "to": "admit"
          },
          {
            "from": "best_interests",
            "to": "admit"
          },
          {
            "from": "admit",
            "to": "end"
          }
        ]
      }
    },
